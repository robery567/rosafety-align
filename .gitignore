# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Jupyter / Colab temp
.virtual_documents/
.jupyter-cache/

# Manuscript — NEVER push any part of the manuscript to the public repo.
# Drafts, figures that appear in the paper, tables, bib, and build
# artifacts all live locally only. This directory is kept out of git
# history by policy (CIKM 2026 Resource Paper — single-blind review,
# and also to avoid pre-print style leakage of unpublished text).
# Remove this line only if publication policy changes.
manuscript/

# LaTeX build artifacts (belt-and-braces; also covered by manuscript/)
*.aux
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.log
*.out
*.synctex.gz
*.toc
*.lot
*.lof

# LLM judge artefacts
experiments/.judge_cache/
experiments/judge_*.jsonl

# data/ is operational Drive-only state. Notebooks create the relevant
# subdirectories on first run (data/probes/<short>/, data/preferences/<short>/,
# data/augmentation/<short>/, etc) via Path.mkdir(parents=True). Public release
# copies the assembled preference dataset, the probe `selected_blocks.json`,
# and the smoke marker into the Zenodo deposit; nothing under data/ is tracked
# in this repo.
#
# This wholesale ignore replaces an earlier attempt to track empty .gitkeep
# files (then small README.md files) inside data/<subdir>/. Drive sync silently
# deletes both pattern types, so we stopped tracking data/ at all.
data/

# Local working files
*.swp
*.bak
*.tmp

# Submission helper files (contain manuscript content; keep local).
easychair_submission.txt
_abstract_check.txt

# Internal experiment log — keep local only.
EXPERIMENT_LOG.md
