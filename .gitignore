# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Jupyter / Colab temp
.virtual_documents/
.jupyter-cache/

# Manuscript — NEVER push any part of the manuscript to the public repo.
# Drafts, figures that appear in the paper, tables, bib, and build
# artifacts all live locally only. This directory is kept out of git
# history by policy (CIKM 2026 Resource Paper — single-blind review,
# and also to avoid pre-print style leakage of unpublished text).
# Remove this line only if publication policy changes.
manuscript/

# LaTeX build artifacts (belt-and-braces; also covered by manuscript/)
*.aux
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.log
*.out
*.synctex.gz
*.toc
*.lot
*.lof

# LLM judge artefacts
experiments/.judge_cache/
experiments/judge_*.jsonl

# Smoke-test artefacts (Drive-only; never tracked).
# The smoke set is reproducible from the seed in the notebook; failure
# dumps and per-pair audits are diagnostic state that lives next to the
# data on Drive, not in the repo.
data/smoke/

# Per-anchor smoke-gate marker files written by notebook 00 and read by
# notebook 02's pre-flight cell. Operational state, not code or data.
data/preferences/*/smoke.json

# Per-anchor preference pipeline artefacts (Drive-only; reproducible from
# the seeds and prompts). Stage 1 rejected samples, Stage 2 chosen
# samples, the assembled preference pairs, and the meta sidecar all live
# on Drive. Public release will copy the assembled pairs to Zenodo + HF
# under a dedicated v1 tag, not from this repo's working directory.
data/preferences/*/stage1_rejected.jsonl
data/preferences/*/stage2_chosen.jsonl
data/preferences/*/preferences_v*.jsonl
data/preferences/*/preferences_v*.meta.json

# Per-anchor refusal-direction probe artefacts (Drive-only; reproducible
# from the frozen probe set and seed). Hidden states, block scores,
# selected blocks, and meta all live on Drive. Public release will copy
# selected_blocks.json + meta.json into the Zenodo deposit; the bulky
# hidden_states.pt stays Drive-only.
data/probes/probe_set.jsonl
data/probes/*/hidden_states.pt
data/probes/*/block_directions.pt
data/probes/*/block_scores.json
data/probes/*/selected_blocks.json
data/probes/*/meta.json
data/probes/*/score_curve.png

# Train / dev / holdout assignment file -- regenerable from seed 0xBADA55
# in notebook 02, kept on Drive only.
data/splits/split_v*.json

# Local working files
*.swp
*.bak
*.tmp

# Submission helper files (contain manuscript content; keep local).
easychair_submission.txt
_abstract_check.txt

# Internal experiment log — keep local only.
EXPERIMENT_LOG.md
